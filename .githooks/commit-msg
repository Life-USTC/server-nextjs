#!/bin/sh

if ! command -v bun >/dev/null 2>&1; then
  echo "Bun is not installed. Please install Bun first." >&2
  exit 1
fi

echo "Running: bunx commitlint --edit $1"
if ! bunx commitlint --edit "$1"; then
  echo "Commit message does not follow the project convention. Commit aborted." >&2
  exit 1
fi

exit 0
