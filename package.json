{
  "name": "life-ustc-server-nextjs",
  "version": "0.1.0",
  "private": true,
  "description": "USTC Life Server - Course and schedule management API using Next.js",
  "packageManager": "bun@1.3.7",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "prebuild": "bun run prisma:generate && bun run openapi:generate && bun run openapi:types",
    "start": "next start",
    "check": "biome check",
    "format": "biome format",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --reporter=list",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install chromium",
    "check:e2e": "bun run tools/check-e2e-conventions.ts",
    "commitlint:last": "commitlint --from HEAD~1 --to HEAD",
    "commitlint:main": "commitlint --from origin/main --to HEAD",
    "hooks:install": "git config core.hooksPath .githooks && chmod +x .githooks/pre-commit .githooks/commit-msg",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:reset": "prisma migrate reset",
    "prisma:deploy": "prisma migrate deploy",
    "openapi:generate": "next-openapi-gen generate && bun run openapi:postprocess",
    "openapi:postprocess": "bun run tools/openapi-postprocess.ts",
    "openapi:types": "bunx openapi-typescript \"public/openapi.generated.json\" -o \"src/generated/openapi.ts\"",
    "dev:seed-scenarios": "bun run tools/seed-dev-scenarios.ts",
    "dev:reset-scenarios": "bun run tools/reset-dev-scenarios.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@aws-sdk/client-s3": "^3.1001.0",
    "@aws-sdk/s3-request-presigner": "^3.1001.0",
    "@base-ui/react": "^1.2.0",
    "@mdx-js/mdx": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@modelcontextprotocol/sdk": "1.27.1",
    "@phosphor-icons/react": "^2.1.10",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@types/pg": "^8.18.0",
    "class-variance-authority": "^0.7.1",
    "cli-progress": "^3.12.0",
    "clsx": "^2.1.1",
    "commander": "^14.0.3",
    "dayjs": "^1.11.19",
    "diff": "^5.2.2",
    "dotenv": "^17.3.1",
    "ical-generator": "^10.0.0",
    "jose": "^6.1.3",
    "katex": "^0.16.33",
    "lucide-react": "^0.562.0",
    "next": "^16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "next-intl": "^4.8.3",
    "next-themes": "^0.4.6",
    "openapi-fetch": "^0.17.0",
    "pg": "^8.19.0",
    "pinyin-pro": "^3.28.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "rehype-attr": "^4.1.1",
    "rehype-katex": "^7.0.1",
    "rehype-sanitize": "^6.0.0",
    "remark-directive": "^4.0.0",
    "remark-emoji": "^5.0.2",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "sass": "^1.97.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "unist-util-visit": "^5.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.8",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/cli-progress": "^3.11.6",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "baseline-browser-mapping": "^2.10.0",
    "next-openapi-gen": "^0.10.3",
    "openapi-typescript": "^7.13.0",
    "prisma": "^7.4.2",
    "prisma-zod-generator": "^2.1.4",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
