{
  "name": "life-ustc-server-nextjs",
  "version": "0.1.0",
  "private": true,
  "description": "USTC Life Server - Course and schedule management API using Next.js",
  "packageManager": "bun@1.3.13",
  "engines": {
    "bun": ">=1.3.13 <1.4"
  },
  "scripts": {
    "app:prepare": "bun run app:prepare:runtime",
    "app:prepare:dev": "bun run prisma:generate && bun run app:prepare:runtime",
    "app:prepare:runtime": "bun run prisma:deploy",
    "app:start:dev": "bun run tools/dev/util/start-app.ts",
    "build": "next build",
    "build:release": "bun run build && bun run build:tools",
    "build:tools": "bun build tools/production/load/load-from-static.ts --target=bun --outdir=dist/tools/production/load --external '@prisma/*' --external pg",
    "check": "biome check",
    "check:all": "bun run check && bun run check:features && bun run check:i18n && bun run check:routes",
    "check:e2e": "bun run tools/dev/check/check-e2e-conventions.ts",
    "check:features": "bun run tools/dev/check/check-features-doc.ts",
    "check:i18n": "bun run tools/dev/check/check-i18n-keys.ts",
    "check:routes": "bun run tools/dev/check/check-route-conventions.ts",
    "check:static-import": "bun run tools/dev/check/check-static-import-regression.ts",
    "commitlint:last": "commitlint --from HEAD~1 --to HEAD",
    "commitlint:main": "commitlint --from origin/main --to HEAD",
    "dev": "bun run app:prepare:dev && bun run app:start:dev",
    "dev:docker": "docker compose -f docker-compose.dev.yml --profile app up -d app",
    "dev:down": "docker compose -f docker-compose.dev.yml --profile app down",
    "dev:infra": "docker compose -f docker-compose.dev.yml up -d",
    "dev:minio:e2e": "bun run tools/dev/util/start-playwright-minio.ts",
    "dev:reset-scenarios": "bun run tools/dev/seed/reset-dev-scenarios.ts",
    "dev:seed-scenarios": "bun run tools/dev/seed/seed-dev-scenarios.ts",
    "format": "biome format",
    "health": "bun run tools/dev/util/healthcheck.ts",
    "load:static": "bun dist/tools/production/load/load-from-static.js",
    "openapi:generate": "bun run tools/build/openapi/generate-spec.ts && bun run tools/build/openapi/postprocess-spec.ts",
    "prebuild": "bun run build:artifacts",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:reset": "prisma migrate reset",
    "prisma:studio": "prisma studio",
    "production:load:static": "bun run tools/production/load/load-from-static.ts",
    "production:register-ios-client": "bun run tools/production/util/register-ios-client.ts",
    "release:semantic": "bun run tools/release/run-semantic-release.ts",
    "snapshot:e2e": "bun run tools/dev/artifacts/dump-e2e-snapshots.ts",
    "snapshot:e2e:api": "bun run tools/dev/artifacts/dump-api-snapshots.ts",
    "snapshot:e2e:comment": "bun run tools/dev/artifacts/comment-e2e-snapshot-diff.ts",
    "snapshot:e2e:diff": "bun run tools/dev/artifacts/diff-e2e-snapshots.ts",
    "snapshot:e2e:mcp": "bun run tools/dev/artifacts/dump-mcp-snapshots.ts",
    "snapshot:e2e:pages": "bun run tools/dev/artifacts/dump-page-snapshots.ts",
    "start": "next start",
    "test": "vitest run",
    "test:e2e": "playwright test --reporter=list",
    "test:e2e:bootstrap": "bun run verify:e2e",
    "test:e2e:benchmark": "bun run tools/dev/benchmark/e2e-workers.ts",
    "test:perf": "bun run tools/dev/benchmark/route-perf.ts",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:artifacts": "bun run typecheck && bun run test:e2e:prepare",
    "test:e2e:prepare": "bun run build && bun run tools/dev/util/prepare-playwright-standalone.ts",
    "test:e2e:report": "playwright show-report",
    "test:e2e:server": "bun run tools/dev/util/run-playwright-standalone.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:watch": "vitest",
    "test:integration:setup": "bun run dev:seed-scenarios",
    "test:integration": "bun run test:integration:setup && vitest run --config vitest.integration.config.ts",
    "typecheck": "bun run typecheck:app && bun run typecheck:tests && bun run typecheck:ops",
    "typecheck:app": "tsc --noEmit -p tsconfig.typecheck.json",
    "typecheck:tests": "tsc --noEmit -p tsconfig.typecheck.tests.json",
    "typecheck:ops": "tsc --noEmit -p tsconfig.typecheck.operational.json",
    "verify:e2e": "bun run tools/dev/util/bootstrap-playwright.ts",
    "verify:fast": "bun run check:all && bun run typecheck && bun run test",
    "verify:full": "bun run verify:fast && bun run test:integration && bun run verify:e2e && bun run test:e2e:prepare && bun run test:e2e",
    "build:artifacts": "bun run prisma:generate && bun run openapi:generate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1037.0",
    "@aws-sdk/s3-request-presigner": "^3.1037.0",
    "@base-ui/react": "^1.4.1",
    "@better-auth/oauth-provider": "^1.6.9",
    "@mdx-js/mdx": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@types/pg": "^8.20.0",
    "better-auth": "^1.6.9",
    "class-variance-authority": "^0.7.1",
    "cli-progress": "^3.12.0",
    "clsx": "^2.1.1",
    "commander": "^14.0.3",
    "dayjs": "^1.11.20",
    "diff": "^9.0.0",
    "dotenv": "^17.4.2",
    "ical-generator": "^10.2.0",
    "jose": "^6.2.2",
    "katex": "^0.16.45",
    "lucide-react": "^1.11.0",
    "next": "^16.2.4",
    "next-intl": "^4.9.1",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "pinyin-pro": "^3.28.1",
    "prisma": "7.8.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-markdown": "^10.1.0",
    "rehype-attr": "^4.1.3",
    "rehype-katex": "^7.0.1",
    "rehype-sanitize": "^6.0.0",
    "remark-directive": "^4.0.0",
    "remark-emoji": "^5.0.2",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "sass": "^1.99.0",
    "swagger-ui-dist": "^5.32.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "unist-util-visit": "^5.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@next/bundle-analyzer": "^16.2.4",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/cli-progress": "^3.11.6",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^10.3.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "ajv": "^8.20.0",
    "babel-plugin-react-compiler": "1.0.0",
    "baseline-browser-mapping": "^2.10.21",
    "semantic-release": "24.2.9",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "yaml": "^2.8.3"
  }
}
