{
  "name": "life-ustc-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "USTC Life Server - Course and schedule management API using SvelteKit",
  "packageManager": "bun@1.3.13",
  "engines": {
    "bun": ">=1.3.13 <1.4"
  },
  "scripts": {
    "build": "vite build",
    "check": "biome check",
    "check:all": "bun run check && bun run check:features && bun run check:i18n && bun run check:routes",
    "check:e2e": "bun run tools/dev/check.ts e2e",
    "check:features": "bun run tools/dev/check.ts features",
    "check:i18n": "bun run tools/dev/check.ts i18n",
    "check:routes": "bun run tools/dev/check.ts routes",
    "dev": "svelte-kit sync && bun run prisma generate && bun run prisma migrate deploy && vite dev --host 127.0.0.1 --port 3000 --strictPort",
    "dev:infra:clean": "docker compose -f docker-compose.dev.yml down -v --remove-orphans",
    "dev:down": "docker compose -f docker-compose.dev.yml down",
    "dev:infra": "docker compose -f docker-compose.dev.yml up -d",
    "dev:reset-scenarios": "bun run tools/dev/seed/seed-dev-scenarios.ts --reset",
    "dev:seed-scenarios": "bun run tools/dev/seed/seed-dev-scenarios.ts",
    "deploy:cloudflare": "bun run build && wrangler deploy",
    "format": "biome format",
    "health": "bun --eval \"fetch('http://127.0.0.1:3000/').then((response) => process.exit(response.ok ? 0 : 1), () => process.exit(1))\"",
    "load:static": "bun run tools/load/load-from-static.ts",
    "openapi:generate": "bun run tools/build/openapi/generate-spec.ts",
    "prebuild": "bun run build:artifacts",
    "prisma": "prisma",
    "release:semantic": "semantic-release",
    "snapshot": "bun run tools/dev/artifacts/snapshots/snapshot-capture.ts",
    "test": "vitest run",
    "test:e2e": "bun run test:e2e:prepare && bun run dev:seed-scenarios && playwright test --reporter=list",
    "test:e2e:artifacts": "bun run typecheck && bun run test:e2e:prepare",
    "test:e2e:prepare": "SVELTEKIT_ADAPTER=node bun run build && bun run tools/dev/e2e.ts prepare",
    "test:watch": "vitest",
    "test:integration": "bun run dev:seed-scenarios && vitest run --config vitest.integration.config.ts",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json && tsc --noEmit -p tsconfig.typecheck.json && tsc --noEmit -p tsconfig.typecheck.tests.json && tsc --noEmit -p tsconfig.typecheck.operational.json",
    "verify:edit": "bun run check && bun run typecheck",
    "verify:e2e": "bun run check:e2e",
    "verify:feature": "bun run check:all && bun run typecheck && bun run test",
    "verify:commit": "bun run check:all && bun run typecheck && bun run test",
    "verify:full": "bun run verify:commit && bun run test:integration && bun run verify:e2e && bun run test:e2e",
    "build:artifacts": "svelte-kit sync && bun run prisma generate && bun run openapi:generate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1050.0",
    "@aws-sdk/s3-request-presigner": "^3.1050.0",
    "@better-auth/oauth-provider": "^1.6.11",
    "@internationalized/date": "^3.12.2",
    "@lucide/svelte": "^1.17.0",
    "@mdx-js/mdx": "^3.1.1",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@types/pg": "^8.20.0",
    "better-auth": "^1.6.11",
    "cli-progress": "^3.12.0",
    "clsx": "^2.1.1",
    "commander": "^14.0.3",
    "dayjs": "^1.11.20",
    "diff": "^9.0.0",
    "dotenv": "^17.4.2",
    "ical-generator": "^10.2.0",
    "jose": "^6.2.3",
    "katex": "^0.16.47",
    "pg": "^8.21.0",
    "pinyin-pro": "^3.28.1",
    "prisma": "7.8.0",
    "rehype-attr": "^4.1.3",
    "rehype-katex": "^7.0.1",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-directive": "^4.0.0",
    "remark-emoji": "^5.0.2",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "sass": "^1.99.0",
    "swagger-ui-dist": "^5.32.6",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss-animate": "^1.0.7",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@playwright/test": "^1.60.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^10.3.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.63.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/cli-progress": "^3.11.6",
    "@types/node": "^25.9.1",
    "ajv": "^8.20.0",
    "baseline-browser-mapping": "^2.10.31",
    "bits-ui": "^2.18.1",
    "daisyui": "^5.5.23",
    "semantic-release": "24.2.9",
    "svelte": "^5.56.2",
    "svelte-check": "^4.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.7",
    "wrangler": "4.100.0",
    "yaml": "^2.9.0"
  }
}
