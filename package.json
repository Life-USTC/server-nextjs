{
  "name": "life-ustc-server-nextjs",
  "version": "0.1.0",
  "private": true,
  "description": "USTC Life Server - Course and schedule management API using Next.js",
  "packageManager": "bun@1.3.13",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "build": "next build",
    "build:openapi": "bun run tools/build/openapi/generate-spec.ts && bun run build:openapi:postprocess",
    "build:openapi:postprocess": "bun run tools/build/openapi/postprocess-spec.ts",
    "build:openapi:types": "bun run tools/build/openapi/generate-types.ts",
    "build:tools": "bun build tools/production/load/load-from-static.ts --target=bun --outdir=dist/tools/production/load --external '@prisma/*' --external pg",
    "check": "biome check",
    "check:e2e": "bun run tools/dev/check/check-e2e-conventions.ts",
    "check:features": "bun run tools/dev/check/check-features-doc.ts",
    "check:i18n": "bun run tools/dev/check/check-i18n-keys.ts",
    "check:routes": "bun run tools/dev/check/check-route-conventions.ts",
    "check:static-import": "bun run tools/dev/check/check-static-import-regression.ts",
    "commitlint:last": "commitlint --from HEAD~1 --to HEAD",
    "commitlint:main": "commitlint --from origin/main --to HEAD",
    "dev": "next dev",
    "dev:reset-scenarios": "bun run tools/dev/seed/reset-dev-scenarios.ts",
    "dev:seed-scenarios": "bun run tools/dev/seed/seed-dev-scenarios.ts",
    "format": "biome format",
    "health": "bun -e \"fetch(process.env.HEALTHCHECK_URL ?? 'http://127.0.0.1:3000/').then(r=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))\"",
    "load:static": "bun dist/tools/production/load/load-from-static.js",
    "prebuild": "bun run prisma:generate && bun run build:openapi && bun run build:openapi:types",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:reset": "prisma migrate reset",
    "prisma:studio": "prisma studio",
    "production:load:static": "bun run tools/production/load/load-from-static.ts",
    "production:register-ios-client": "bun run tools/production/util/register-ios-client.ts",
    "start": "next start",
    "test": "vitest run",
    "test:e2e": "playwright test --reporter=list",
    "test:e2e:benchmark": "bun run tools/dev/benchmark/e2e-workers.ts",
    "test:perf": "bun run tools/dev/benchmark/route-perf.ts",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:prepare-server": "bun run tools/dev/util/prepare-playwright-standalone.ts",
    "test:e2e:report": "playwright show-report",
    "test:e2e:ui": "playwright test --ui",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1037.0",
    "@aws-sdk/s3-request-presigner": "^3.1037.0",
    "@base-ui/react": "^1.4.1",
    "@better-auth/oauth-provider": "^1.6.9",
    "@mdx-js/mdx": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@types/pg": "^8.20.0",
    "better-auth": "^1.6.9",
    "class-variance-authority": "^0.7.1",
    "cli-progress": "^3.12.0",
    "clsx": "^2.1.1",
    "commander": "^14.0.3",
    "dayjs": "^1.11.20",
    "diff": "^9.0.0",
    "dotenv": "^17.4.2",
    "ical-generator": "^10.2.0",
    "jose": "^6.2.2",
    "katex": "^0.16.45",
    "lucide-react": "^1.11.0",
    "next": "^16.2.4",
    "next-intl": "^4.9.1",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "pinyin-pro": "^3.28.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-markdown": "^10.1.0",
    "rehype-attr": "^4.1.3",
    "rehype-katex": "^7.0.1",
    "rehype-sanitize": "^6.0.0",
    "remark-directive": "^4.0.0",
    "remark-emoji": "^5.0.2",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "sass": "^1.99.0",
    "swagger-ui-dist": "^5.32.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "unist-util-visit": "^5.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@next/bundle-analyzer": "^16.2.4",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/cli-progress": "^3.11.6",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "ajv": "^8.20.0",
    "babel-plugin-react-compiler": "1.0.0",
    "baseline-browser-mapping": "^2.10.21",
    "prisma": "7.8.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "yaml": "^2.8.3"
  }
}
