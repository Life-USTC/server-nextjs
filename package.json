{
  "name": "life-ustc-server-nextjs",
  "version": "0.1.0",
  "private": true,
  "description": "USTC Life Server - Course and schedule management API using Next.js",
  "packageManager": "bun@1.3.7",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "build": "next build",
    "build:openapi": "bun run tools/build/openapi/generate-spec.ts && bun run build:openapi:postprocess",
    "build:openapi:postprocess": "bun run tools/build/openapi/postprocess-spec.ts",
    "build:openapi:types": "bun run tools/build/openapi/generate-types.ts",
    "build:tools": "bun build tools/production/load/load-from-static.ts --target=bun --outdir=dist/tools/production/load --external '@prisma/*' --external pg",
    "check": "biome check",
    "check:e2e": "bun run tools/dev/check/check-e2e-conventions.ts",
    "check:i18n": "bun run tools/dev/check/check-i18n-keys.ts",
    "commitlint:last": "commitlint --from HEAD~1 --to HEAD",
    "commitlint:main": "commitlint --from origin/main --to HEAD",
    "dev": "next dev",
    "dev:reset-scenarios": "bun run tools/dev/seed/reset-dev-scenarios.ts",
    "dev:seed-scenarios": "bun run tools/dev/seed/seed-dev-scenarios.ts",
    "format": "biome format",
    "health": "bun -e \"fetch(process.env.HEALTHCHECK_URL ?? 'http://127.0.0.1:3000/').then(r=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))\"",
    "hooks:install": "git config core.hooksPath .githooks && chmod +x .githooks/pre-commit .githooks/commit-msg",
    "load:static": "bun dist/tools/production/load/load-from-static.js",
    "prebuild": "bun run prisma:generate & bun run build:openapi && wait && bun run build:openapi:types",
    "prepare": "git config core.hooksPath .githooks || true",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:reset": "prisma migrate reset",
    "prisma:studio": "prisma studio",
    "production:load:static": "bun run tools/production/load/load-from-static.ts",
    "production:register-ios-client": "bun run tools/production/util/register-ios-client.ts",
    "start": "next start",
    "test": "vitest run",
    "test:e2e": "playwright test --reporter=list",
    "test:e2e:benchmark": "bun run tools/dev/benchmark/e2e-workers.ts",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:report": "playwright show-report",
    "test:e2e:ui": "playwright test --ui",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1001.0",
    "@aws-sdk/s3-request-presigner": "^3.1001.0",
    "@base-ui/react": "^1.2.0",
    "@better-auth/oauth-provider": "^1.5.6",
    "@mdx-js/mdx": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@modelcontextprotocol/sdk": "1.27.1",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@types/pg": "^8.18.0",
    "better-auth": "^1.5.6",
    "class-variance-authority": "^0.7.1",
    "cli-progress": "^3.12.0",
    "clsx": "^2.1.1",
    "commander": "^14.0.3",
    "dayjs": "^1.11.19",
    "diff": "^5.2.2",
    "dotenv": "^17.3.1",
    "ical-generator": "^10.0.0",
    "jose": "^6.1.3",
    "katex": "^0.16.33",
    "lucide-react": "^0.562.0",
    "next": "^16.1.6",
    "next-intl": "^4.8.3",
    "next-themes": "^0.4.6",
    "pg": "^8.19.0",
    "pinyin-pro": "^3.28.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "rehype-attr": "^4.1.1",
    "rehype-katex": "^7.0.1",
    "rehype-sanitize": "^6.0.0",
    "remark-directive": "^4.0.0",
    "remark-emoji": "^5.0.2",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "sass": "^1.97.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "unist-util-visit": "^5.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.8",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@next/bundle-analyzer": "^16.2.3",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/cli-progress": "^3.11.6",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "baseline-browser-mapping": "^2.10.0",
    "prisma": "^7.4.2",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
