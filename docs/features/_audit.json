{
  "fields": {
    "id": {
      "type": "String (cuid)",
      "note": "Primary key"
    },
    "action": {
      "type": "AuditAction",
      "note": "Enum value (see below)"
    },
    "userId": {
      "type": "String",
      "note": "Actor who performed the action"
    },
    "targetId": {
      "type": "String?",
      "note": "ID of the affected object"
    },
    "targetType": {
      "type": "String?",
      "note": "\"comment\", \"description\", \"upload\", \"user\""
    },
    "metadata": {
      "type": "Json?",
      "note": "Extra context (body snippet, reason, etc.)"
    },
    "ipAddress": {
      "type": "String?",
      "note": "From x-forwarded-for / x-real-ip"
    },
    "userAgent": {
      "type": "String?",
      "note": "From user-agent header"
    },
    "createdAt": {
      "type": "DateTime",
      "note": "When the action occurred"
    }
  },
  "actions": {
    "comment_create": {
      "trigger": "POST /api/comments",
      "description": "User creates a new comment on an object."
    },
    "comment_edit": {
      "trigger": "PATCH /api/comments/[id]",
      "description": "User edits their own comment."
    },
    "comment_delete": {
      "trigger": "DELETE /api/comments/[id]",
      "description": "User or admin deletes a comment."
    },
    "comment_react": {
      "trigger": "POST /api/comments/[id]/reactions",
      "description": "User adds or removes a reaction on a comment."
    },
    "description_edit": {
      "trigger": "POST /api/descriptions",
      "description": "User updates an object description (content changed)."
    },
    "upload_delete": {
      "trigger": "DELETE /api/uploads/[id]",
      "description": "User or admin deletes an upload."
    },
    "admin_user_suspend": {
      "trigger": "POST /api/admin/suspensions",
      "description": "Admin suspends a user account."
    },
    "admin_user_unsuspend": {
      "trigger": "PATCH /api/admin/suspensions/[id]",
      "description": "Admin lifts a user suspension."
    },
    "admin_comment_moderate": {
      "trigger": "PATCH /api/admin/comments/[id]",
      "description": "Admin hides or moderates a comment."
    },
    "admin_description_moderate": {
      "trigger": "Reserved",
      "description": "Reserved for future admin description moderation actions."
    }
  },
  "writer": "writeAuditLog in src/lib/audit/write-audit-log.ts writes a record. Calls are fire-and-forget (.catch(() => {})) so audit failures never block the main request."
}
