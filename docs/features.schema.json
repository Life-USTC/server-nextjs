{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./features.schema.json",
  "title": "Life@USTC Features",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "meta",
    "product",
    "models",
    "enums",
    "ui",
    "modules",
    "cases",
    "audit"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "language", "file", "query", "queries"],
      "properties": {
        "name": {
          "$ref": "#/$defs/shortText"
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "language": {
          "$ref": "#/$defs/shortText"
        },
        "file": {
          "type": "string",
          "const": "docs/features.yml"
        },
        "query": {
          "type": "string",
          "enum": ["yq"]
        },
        "queries": {
          "type": "object",
          "minProperties": 1,
          "maxProperties": 32,
          "propertyNames": {
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "additionalProperties": {
            "type": "string",
            "minLength": 1,
            "maxLength": 700,
            "pattern": "^yq .+ docs/features\\.yml$"
          }
        }
      }
    },
    "product": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "priority",
        "surfaces",
        "roles",
        "terms",
        "workflow",
        "display_conventions"
      ],
      "properties": {
        "priority": {
          "$ref": "#/$defs/compactStringList"
        },
        "surfaces": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["web", "rest", "mcp"]
          }
        },
        "roles": {
          "type": "object",
          "additionalProperties": false,
          "required": ["anon", "user", "admin", "agent"],
          "properties": {
            "anon": {
              "$ref": "#/$defs/roleDefinition"
            },
            "user": {
              "$ref": "#/$defs/roleDefinition"
            },
            "admin": {
              "$ref": "#/$defs/roleDefinition"
            },
            "agent": {
              "$ref": "#/$defs/roleDefinition"
            }
          }
        },
        "terms": {
          "type": "object",
          "minProperties": 1,
          "maxProperties": 24,
          "propertyNames": {
            "minLength": 1,
            "maxLength": 48
          },
          "additionalProperties": {
            "$ref": "#/$defs/text"
          }
        },
        "workflow": {
          "$ref": "#/$defs/compactStringList"
        },
        "display_conventions": {
          "$ref": "#/$defs/ruleMap"
        }
      }
    },
    "models": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^[A-Z][A-Za-z0-9]*$"
      },
      "additionalProperties": {
        "$ref": "#/$defs/prismaModel"
      }
    },
    "enums": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[A-Z][A-Za-z0-9]*$"
      },
      "additionalProperties": {
        "type": "array",
        "minItems": 1,
        "maxItems": 64,
        "uniqueItems": true,
        "items": {
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9_]*$",
          "maxLength": 64
        }
      }
    },
    "ui": {
      "type": "object",
      "minProperties": 1,
      "maxProperties": 24,
      "propertyNames": {
        "minLength": 1,
        "maxLength": 64
      },
      "additionalProperties": {
        "type": "string",
        "minLength": 1,
        "maxLength": 700
      }
    },
    "modules": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      },
      "additionalProperties": {
        "$ref": "#/$defs/module"
      }
    },
    "cases": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      },
      "additionalProperties": {
        "$ref": "#/$defs/case"
      }
    },
    "audit": {
      "$ref": "#/$defs/audit"
    }
  },
  "$defs": {
    "shortText": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 520
    },
    "compactStringList": {
      "type": "array",
      "minItems": 1,
      "maxItems": 60,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/text"
      }
    },
    "ruleMap": {
      "type": "object",
      "minProperties": 1,
      "maxProperties": 24,
      "propertyNames": {
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      },
      "additionalProperties": {
        "$ref": "#/$defs/text"
      }
    },
    "permission": {
      "type": "string",
      "enum": ["read", "write", "update", "delete", "moderate", "manage"]
    },
    "roleDefinition": {
      "oneOf": [
        {
          "$ref": "#/$defs/text"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["description", "base_permissions"],
          "properties": {
            "description": {
              "$ref": "#/$defs/text"
            },
            "base_permissions": {
              "type": "array",
              "minItems": 1,
              "maxItems": 6,
              "uniqueItems": true,
              "items": {
                "$ref": "#/$defs/permission"
              }
            },
            "scope": {
              "$ref": "#/$defs/text"
            },
            "inherits": {
              "$ref": "#/$defs/shortText"
            },
            "notes": {
              "$ref": "#/$defs/text"
            }
          }
        }
      ]
    },
    "accessEntry": {
      "oneOf": [
        {
          "$ref": "#/$defs/text"
        },
        {
          "type": "array",
          "minItems": 1,
          "maxItems": 6,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/permission"
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["permissions"],
          "properties": {
            "permissions": {
              "type": "array",
              "minItems": 1,
              "maxItems": 6,
              "uniqueItems": true,
              "items": {
                "$ref": "#/$defs/permission"
              }
            },
            "scope": {
              "$ref": "#/$defs/text"
            },
            "notes": {
              "$ref": "#/$defs/text"
            }
          }
        }
      ]
    },
    "authLevel": {
      "type": "string",
      "enum": ["anon", "user", "admin"]
    },
    "surfaceStatus": {
      "type": "string",
      "enum": ["stable", "planned", "unavailable"]
    },
    "prismaModel": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fields"],
      "properties": {
        "fields": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": {
            "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
          },
          "additionalProperties": {
            "type": "string",
            "minLength": 1,
            "maxLength": 220
          }
        },
        "constraints": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 180,
            "pattern": "^@@(id|unique|index)\\("
          }
        }
      }
    },
    "routeEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^/",
          "maxLength": 160
        },
        "method": {
          "type": "string",
          "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"],
          "default": "GET"
        },
        "description": {
          "$ref": "#/$defs/text"
        },
        "returns": {
          "type": "string",
          "minLength": 1,
          "maxLength": 180
        },
        "content_type": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "status": {
          "type": "integer",
          "minimum": 100,
          "maximum": 599
        },
        "auth": {
          "$ref": "#/$defs/authLevel"
        },
        "notes": {
          "$ref": "#/$defs/notes"
        }
      }
    },
    "toolEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "maxLength": 80
        },
        "description": {
          "$ref": "#/$defs/text"
        },
        "status": {
          "$ref": "#/$defs/surfaceStatus"
        },
        "auth": {
          "$ref": "#/$defs/authLevel"
        },
        "returns": {
          "type": "string",
          "minLength": 1,
          "maxLength": 220
        },
        "rest_equivalent": {
          "type": "string",
          "pattern": "^(GET|POST|PUT|PATCH|DELETE) /",
          "maxLength": 180
        },
        "notes": {
          "$ref": "#/$defs/notes"
        }
      },
      "if": {
        "properties": {
          "status": {
            "const": "unavailable"
          }
        },
        "required": ["status"]
      },
      "then": {
        "not": {
          "anyOf": [
            {
              "required": ["returns"]
            },
            {
              "required": ["rest_equivalent"]
            }
          ]
        }
      }
    },
    "notes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/text"
      }
    },
    "modelRef": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^[A-Z][A-Za-z0-9]*$"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["name"],
          "properties": {
            "name": {
              "type": "string",
              "pattern": "^[A-Z][A-Za-z0-9]*$"
            },
            "role": {
              "type": "string",
              "enum": ["primary", "context"]
            }
          }
        }
      ]
    },
    "toolGroup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "tools"],
      "properties": {
        "name": {
          "$ref": "#/$defs/shortText"
        },
        "tools": {
          "type": "array",
          "minItems": 1,
          "maxItems": 24,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$",
            "maxLength": 80
          }
        }
      }
    },
    "links": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "models": {
          "type": "array",
          "minItems": 1,
          "maxItems": 12,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/modelRef"
          }
        },
        "ui": {
          "$ref": "#/$defs/compactStringList"
        }
      }
    },
    "display": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "fields": {
          "$ref": "#/$defs/compactStringList"
        },
        "filters": {
          "$ref": "#/$defs/compactStringList"
        }
      }
    },
    "webSurface": {
      "oneOf": [
        {
          "$ref": "#/$defs/surfaceStatus"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["pages"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["stable", "planned"]
            },
            "pages": {
              "type": "array",
              "minItems": 1,
              "maxItems": 12,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "pattern": "^/",
                "maxLength": 160
              }
            }
          }
        }
      ]
    },
    "restSurface": {
      "oneOf": [
        {
          "$ref": "#/$defs/surfaceStatus"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["routes"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["stable", "planned"]
            },
            "routes": {
              "type": "array",
              "minItems": 1,
              "maxItems": 12,
              "items": {
                "$ref": "#/$defs/routeEntry"
              }
            }
          }
        }
      ]
    },
    "mcpSurface": {
      "oneOf": [
        {
          "$ref": "#/$defs/surfaceStatus"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "anyOf": [
            {
              "required": ["tools"]
            },
            {
              "required": ["groups"]
            }
          ],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["stable", "planned"]
            },
            "tools": {
              "type": "array",
              "minItems": 1,
              "maxItems": 12,
              "items": {
                "$ref": "#/$defs/toolEntry"
              }
            },
            "groups": {
              "type": "array",
              "minItems": 1,
              "maxItems": 16,
              "items": {
                "$ref": "#/$defs/toolGroup"
              }
            }
          }
        }
      ]
    },
    "capability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "auth"],
      "properties": {
        "title": {
          "$ref": "#/$defs/shortText"
        },
        "description": {
          "$ref": "#/$defs/text"
        },
        "auth": {
          "$ref": "#/$defs/authLevel"
        },
        "links": {
          "$ref": "#/$defs/links"
        },
        "display": {
          "$ref": "#/$defs/display"
        },
        "rules": {
          "$ref": "#/$defs/ruleMap"
        },
        "web": {
          "$ref": "#/$defs/webSurface"
        },
        "rest": {
          "$ref": "#/$defs/restSurface"
        },
        "mcp": {
          "$ref": "#/$defs/mcpSurface"
        }
      }
    },
    "moduleAccess": {
      "type": "object",
      "additionalProperties": false,
      "required": ["anon", "user", "admin", "agent"],
      "properties": {
        "anon": {
          "$ref": "#/$defs/accessEntry"
        },
        "user": {
          "$ref": "#/$defs/accessEntry"
        },
        "admin": {
          "$ref": "#/$defs/accessEntry"
        },
        "agent": {
          "$ref": "#/$defs/accessEntry"
        }
      }
    },
    "module": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "access", "rules", "capabilities"],
      "properties": {
        "name": {
          "$ref": "#/$defs/shortText"
        },
        "access": {
          "$ref": "#/$defs/moduleAccess"
        },
        "rules": {
          "$ref": "#/$defs/ruleMap"
        },
        "capabilities": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": {
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "additionalProperties": {
            "$ref": "#/$defs/capability"
          }
        }
      }
    },
    "caseAffects": {
      "type": "object",
      "additionalProperties": false,
      "required": ["module"],
      "properties": {
        "module": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "capability": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        }
      }
    },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rules", "decisions"],
      "properties": {
        "affects": {
          "type": "array",
          "minItems": 1,
          "maxItems": 12,
          "items": {
            "$ref": "#/$defs/caseAffects"
          }
        },
        "rules": {
          "type": "object",
          "minProperties": 1,
          "maxProperties": 16,
          "propertyNames": {
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "additionalProperties": {
            "$ref": "#/$defs/compactStringList"
          }
        },
        "decisions": {
          "$ref": "#/$defs/compactStringList"
        }
      }
    },
    "auditTrigger": {
      "type": "string",
      "oneOf": [
        {
          "pattern": "^(GET|POST|PUT|PATCH|DELETE) /"
        },
        {
          "const": "Reserved"
        }
      ],
      "maxLength": 180
    },
    "auditAction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trigger"],
      "properties": {
        "trigger": {
          "$ref": "#/$defs/auditTrigger"
        },
        "description": {
          "$ref": "#/$defs/text"
        }
      }
    },
    "auditField": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "note"],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "note": {
          "$ref": "#/$defs/text"
        }
      }
    },
    "audit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fields", "actions", "writer"],
      "properties": {
        "fields": {
          "type": "object",
          "minProperties": 1,
          "maxProperties": 32,
          "propertyNames": {
            "pattern": "^[A-Za-z][A-Za-z0-9_]*$"
          },
          "additionalProperties": {
            "$ref": "#/$defs/auditField"
          }
        },
        "actions": {
          "type": "object",
          "minProperties": 1,
          "maxProperties": 32,
          "propertyNames": {
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "additionalProperties": {
            "$ref": "#/$defs/auditAction"
          }
        },
        "writer": {
          "type": "string",
          "minLength": 1,
          "maxLength": 320
        }
      }
    }
  }
}
