# Core app
# Host-native dev (`bun run dev`) uses 127.0.0.1 endpoints below and auto-runs
# `prisma generate` + `prisma migrate deploy` before starting Next.js.
# Docker Compose app dev (`bun run dev:docker`)
# overrides DATABASE_URL and S3 endpoint to use service DNS names.
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/life_ustc_dev"
JWT_SECRET="replace-with-random-secret"
WEBHOOK_SECRET="replace-with-random-secret"
AUTH_SECRET="replace-with-random-secret"
APP_PUBLIC_ORIGIN="http://localhost:3000"
APP_CANONICAL_ORIGIN="https://life-ustc.tiankaima.dev"
BETTER_AUTH_URL="http://localhost:3000"
# Optional dedicated key for encrypting OIDC client secrets at rest.
# OIDC_CLIENT_SECRET_ENCRYPTION_KEY="replace-with-random-secret"

# Storage
# These values also drive the shared MinIO defaults used by `docker-compose.dev.yml`
# and the standalone Playwright MinIO helper.
S3_BUCKET="life-ustc-dev"
AWS_REGION="us-east-1"
AWS_ENDPOINT_URL_S3="http://127.0.0.1:9000"
AWS_ACCESS_KEY_ID="minioadmin"
AWS_SECRET_ACCESS_KEY="minioadmin"
MINIO_API_CORS_ALLOW_ORIGIN="http://127.0.0.1:3000,http://localhost:3000"
# Optional MinIO overrides:
# MINIO_IMAGE="minio/minio:latest"
# MINIO_CONTAINER_NAME="life-ustc-minio-dev"
# MINIO_PORT="9000"
# MINIO_CONSOLE_PORT="9001"
# MINIO_INTERNAL_ENDPOINT="http://minio:9000"

# OAuth / OIDC providers
# AUTH_GITHUB_ID=""
# AUTH_GITHUB_SECRET=""
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""
AUTH_OIDC_ISSUER="https://sso-proxy.lug.ustc.edu.cn/auth/oauth2"
AUTH_OIDC_CLIENT_ID=""
AUTH_OIDC_CLIENT_SECRET=""
# Optional dedicated secret for Better Auth OAuth proxy.
# Set the same value on production and any preview/local environment that
# should complete provider sign-in via the production callback URL.
# OAUTH_PROXY_SECRET="replace-with-shared-random-secret"

# Dev-only defaults
# UPLOAD_TOTAL_QUOTA_MB="1024"
# DEV_DEBUG_USERNAME="dev-user"
# DEV_DEBUG_NAME="Dev Debug User"
# DEV_ADMIN_USERNAME="dev-admin"
# DEV_ADMIN_NAME="Dev Admin User"
# When E2E_DEBUG_AUTH=1 (e.g. Playwright), set both — no defaults in non-dev NODE_ENV:
# DEV_DEBUG_PASSWORD="..."
# DEV_ADMIN_PASSWORD="..."
